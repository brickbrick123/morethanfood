---
interface Props {
  class?: string;
  ariaHidden?: boolean;
}
const { class: className = '', ariaHidden = false } = Astro.props;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 200 200"
  role={ariaHidden ? undefined : 'img'}
  aria-label={ariaHidden ? undefined : 'More Than Food'}
  aria-hidden={ariaHidden ? 'true' : undefined}
  class={className}
>
  <!-- Sun rays — 8 rays at 45° intervals, spaced out from sun -->
  <g stroke="#D97A3A" stroke-width="5" stroke-linecap="round" fill="none">
    <line x1="100" y1="50" x2="100" y2="40" />
    <line x1="110" y1="54" x2="117" y2="47" />
    <line x1="114" y1="64" x2="124" y2="64" />
    <line x1="110" y1="74" x2="117" y2="81" />
    <line x1="100" y1="78" x2="100" y2="88" />
    <line x1="90" y1="74" x2="83" y2="81" />
    <line x1="86" y1="64" x2="76" y2="64" />
    <line x1="90" y1="54" x2="83" y2="47" />
  </g>
  <!-- Sun body -->
  <circle cx="100" cy="64" r="8" fill="#D97A3A" />
  <!-- Bowl (uses currentColor so it adapts to dark or light backgrounds) -->
  <path
    d="M 48 100 A 52 52 0 0 0 152 100 Z"
    fill="none"
    stroke="currentColor"
    stroke-width="10"
    stroke-linejoin="round"
    stroke-linecap="round"
  />
</svg>
