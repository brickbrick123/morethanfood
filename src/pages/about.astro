---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';

import aboutImg from '../assets/images/about.jpg';
import eventImg from '../assets/images/home-event.jpg';

const galleryModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/gallery/*.jpg',
  { eager: true }
);
const gallery = Object.entries(galleryModules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, mod]) => mod.default);

const founders = ['Bricker Thiel', 'Brenden Swann', 'Colin Weeks'];

const values = [
  {
    title: 'Perspective',
    body: 'Our volunteers gain perspective through their exposure to the members and facilities in our homeless communities.',
  },
  {
    title: 'Exposure',
    body: 'We bring together two communities that rarely share a table, so each side sees the other clearly and humanly.',
  },
  {
    title: 'Hope',
    body: 'Members of shelters see that their communities care enough to show up and offer their service.',
  },
];
---

<BaseLayout
  title="Our Story"
  description="More Than Food was founded in 2023 by three student-athletes at John Carroll University determined to bring two communities together through a shared meal."
>
  <!-- ================= HEADER ================= -->
  <section class="bg-forest pb-16 pt-20 sm:pb-20 sm:pt-28">
    <div class="container-content">
      <span class="eyebrow-light">
        <span class="h-px w-7 bg-current opacity-50"></span>
        The story behind More Than Food
      </span>
      <h1
        class="mt-6 max-w-3xl text-balance font-display text-[2.5rem] font-900 leading-[1.05] tracking-tight text-cream sm:text-6xl"
      >
        How More Than Food was born.
      </h1>
      <p class="mt-5 max-w-xl text-pretty text-lg leading-relaxed text-cream/75">
        It started with three teammates, a simple breakfast, and a belief that a
        shared meal can close the distance between people.
      </p>
    </div>
  </section>

  <!-- ================= ORIGIN STORY ================= -->
  <section class="bg-cream py-20 sm:py-28">
    <div class="container-content">
      <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
        <div class="reveal">
          <div class="photo-frame aspect-[4/5] shadow-card">
            <Image
              src={aboutImg}
              alt="More Than Food founders and volunteers at a community service event"
              widths={[480, 760, 1080]}
              sizes="(min-width: 1024px) 46vw, 90vw"
            />
          </div>
        </div>

        <div class="reveal" style="transition-delay: 120ms;">
          <SectionHeading
            eyebrow="Founded 2023"
            title="Three student-athletes, one local mission."
          />
          <p class="mt-6 text-pretty leading-relaxed text-ink/75">
            More Than Food was founded by three student-athletes at John Carroll
            University wanting to make an impact on the local community.
          </p>
          <ul class="mt-6 flex flex-wrap gap-3">
            {
              founders.map((name) => (
                <li
                  class="rounded-full border border-forest/15 bg-paper px-5 py-2.5 text-sm font-semibold text-forest"
                >
                  {name}
                </li>
              ))
            }
          </ul>
          <p class="mt-6 text-pretty leading-relaxed text-ink/75">
            Proper nutrient intake plays such a pivotal role in being a top
            performing athlete, so we take great pride in eating healthy foods —
            which is exactly what we provide at our service events.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= BREAKFAST OF CHAMPIONS ================= -->
  <section class="bg-forest py-20 sm:py-28">
    <div class="container-content">
      <div class="grid items-center gap-12 lg:grid-cols-[0.95fr_1.05fr] lg:gap-16">
        <div class="reveal">
          <SectionHeading
            eyebrow="What we serve"
            tone="light"
            title="A protein-packed breakfast of champions."
          />
          <p class="mt-6 text-pretty leading-relaxed text-cream/75">
            In our traditional breakfast events, we feed individuals potatoes,
            eggs, and cheese, all wrapped in a tortilla to make a protein-packed
            breakfast of champions.
          </p>
          <p class="mt-4 text-pretty leading-relaxed text-cream/75">
            It is the same fuel we rely on as athletes — and we believe everyone
            who joins us at the table deserves nothing less.
          </p>
        </div>

        <div class="reveal" style="transition-delay: 120ms;">
          <div class="photo-frame aspect-[16/11] shadow-lift">
            <Image
              src={eventImg}
              alt="A More Than Food breakfast being prepared and served"
              widths={[520, 820, 1120]}
              sizes="(min-width: 1024px) 50vw, 90vw"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= VALUES ================= -->
  <section class="bg-paper py-20 sm:py-28">
    <div class="container-content">
      <SectionHeading
        eyebrow="Why it matters"
        title="Perspective, exposure, and hope."
        intro="Our events offer invaluable lessons that reach far beyond the meal itself — for everyone who takes part."
        align="center"
        class="mb-14"
      />
      <div class="grid gap-6 sm:grid-cols-3 lg:gap-8">
        {
          values.map((value, i) => (
            <article
              class="reveal flex flex-col rounded-4xl border border-forest/10 bg-cream p-8"
              style={`transition-delay: ${i * 110}ms;`}
            >
              <span class="font-display text-5xl font-900 text-ember-300">
                {String(i + 1).padStart(2, '0')}
              </span>
              <h3 class="mt-4 font-display text-xl font-700 text-forest">
                {value.title}
              </h3>
              <p class="mt-2 text-pretty leading-relaxed text-ink/70">
                {value.body}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ================= GLIMPSE STRIP ================= -->
  <section class="bg-cream pb-4 pt-20 sm:pt-28">
    <div class="container-content">
      <SectionHeading
        eyebrow="A glimpse"
        title="Moments from the table"
        class="mb-12"
      />
    </div>
    <div class="container-content">
      <div class="grid grid-cols-2 gap-3 sm:gap-4 lg:grid-cols-4">
        {
          [gallery[2], gallery[7], gallery[12], gallery[17]]
            .filter(Boolean)
            .map((img, i) => (
              <div
                class="photo-frame reveal aspect-square"
                style={`transition-delay: ${i * 70}ms;`}
              >
                <Image
                  src={img}
                  alt="More Than Food volunteers and community members sharing a meal"
                  widths={[280, 440, 600]}
                  sizes="(min-width: 1024px) 23vw, 45vw"
                />
              </div>
            ))
        }
      </div>
      <div class="mt-8 flex justify-center">
        <a href="/service-in-action" class="btn-outline">See the full gallery</a>
      </div>
    </div>
  </section>

  <!-- ================= CTA ================= -->
  <section class="bg-cream py-20 sm:py-28">
    <div class="container-content">
      <div
        class="reveal flex flex-col items-center gap-6 rounded-4xl bg-forest px-8 py-14 text-center sm:px-12"
      >
        <h2 class="max-w-2xl text-balance font-display text-3xl font-800 text-cream sm:text-4xl">
          Be part of the next chapter.
        </h2>
        <p class="max-w-lg text-pretty text-cream/75">
          Every contribution helps us serve another meal and bring another
          community together. There is a place for you at our table.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/donate" class="btn-primary">Donate Here</a>
          <a href="/contact" class="btn-ghost-light">Get involved</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
