---
import type { ImageMetadata } from 'astro';
import { Image, getImage } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';

const galleryModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/gallery/*.jpg',
  { eager: true }
);
// Sort newest first (higher gallery-NN.jpg numbers = more recent additions).
const gallery = Object.entries(galleryModules)
  .sort(([a], [b]) => b.localeCompare(a))
  .map(([, mod]) => mod.default);

// Pre-render a large version of each photo for the lightbox.
const fullVersions = await Promise.all(
  gallery.map((img) => getImage({ src: img, width: 1600, format: 'webp' }))
);
---

<BaseLayout
  title="Service in Action"
  description="The people who make a difference — moments from More Than Food service events, where volunteers and community members come together over a shared meal."
>
  <!-- ================= HEADER ================= -->
  <section class="bg-forest pb-16 pt-20 sm:pb-20 sm:pt-28">
    <div class="container-content">
      <span class="eyebrow-light">
        <span class="h-px w-7 bg-current opacity-50"></span>
        Service in Action
      </span>
      <h1
        class="mt-6 max-w-3xl text-balance font-display text-[2.5rem] font-900 leading-[1.05] tracking-tight text-cream sm:text-6xl"
      >
        The people who make a difference.
      </h1>
      <p class="mt-5 max-w-xl text-pretty text-lg leading-relaxed text-cream/75">
        Every photo here is a moment of communion — volunteers, athletes,
        families, and neighbors coming together around a shared table. This is
        what More Than Food looks like.
      </p>
    </div>
  </section>

  <!-- ================= GALLERY ================= -->
  <section class="bg-cream py-14 sm:py-20">
    <div class="container-content">
      <div class="gap-3 sm:gap-4 [column-fill:_balance] columns-2 lg:columns-3">
        {
          gallery.map((img, i) => (
            <button
              type="button"
              class="group reveal mb-3 block w-full break-inside-avoid overflow-hidden rounded-2xl sm:mb-4"
              style={`transition-delay: ${(i % 6) * 60}ms;`}
              data-lightbox
              data-index={i}
              data-full={fullVersions[i].src}
              data-alt={`More Than Food service event photo ${i + 1}`}
              aria-label={`Open photo ${i + 1} of ${gallery.length}`}
            >
              <span class="photo-frame block">
                <Image
                  src={img}
                  alt={`More Than Food service event photo ${i + 1}`}
                  widths={[320, 520, 760]}
                  sizes="(min-width: 1024px) 32vw, 48vw"
                  class="!transition-transform !duration-500 group-hover:!scale-105"
                />
              </span>
            </button>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ================= CTA ================= -->
  <section class="bg-paper py-18 sm:py-24">
    <div class="container-content">
      <div
        class="reveal flex flex-col items-center gap-6 rounded-4xl bg-forest px-8 py-14 text-center sm:px-12"
      >
        <h2 class="max-w-2xl text-balance font-display text-3xl font-800 text-cream sm:text-4xl">
          Want to see your community in the next photo?
        </h2>
        <p class="max-w-lg text-pretty text-cream/75">
          Whether you give, volunteer, or simply spread the word — there is a
          place for you at our table.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/donate" class="btn-primary">Donate Here</a>
          <a href="/contact" class="btn-ghost-light">Get involved</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= LIGHTBOX ================= -->
  <div
    id="lightbox"
    class="fixed inset-0 z-[90] hidden items-center justify-center bg-ink/95 p-4 backdrop-blur-sm"
    role="dialog"
    aria-modal="true"
    aria-label="Photo viewer"
  >
    <button
      id="lb-close"
      type="button"
      class="absolute right-4 top-4 flex h-12 w-12 items-center justify-center rounded-full bg-cream/10 text-cream transition-colors hover:bg-ember hover:text-ink"
      aria-label="Close photo viewer"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
        <line x1="6" y1="6" x2="18" y2="18"></line>
        <line x1="6" y1="18" x2="18" y2="6"></line>
      </svg>
    </button>

    <button
      id="lb-prev"
      type="button"
      class="absolute left-3 top-1/2 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-cream/10 text-cream transition-colors hover:bg-ember hover:text-ink sm:left-6"
      aria-label="Previous photo"
    >
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <button
      id="lb-next"
      type="button"
      class="absolute right-3 top-1/2 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-cream/10 text-cream transition-colors hover:bg-ember hover:text-ink sm:right-6"
      aria-label="Next photo"
    >
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>

    <figure class="flex max-h-full max-w-5xl flex-col items-center gap-3">
      <img
        id="lb-image"
        src=""
        alt=""
        class="max-h-[82vh] w-auto rounded-xl object-contain shadow-lift"
      />
      <figcaption id="lb-caption" class="text-sm text-cream/60"></figcaption>
    </figure>
  </div>

  <script>
    const lightbox = document.getElementById('lightbox');
    const lbImage = document.getElementById('lb-image') as HTMLImageElement | null;
    const lbCaption = document.getElementById('lb-caption');
    const triggers = Array.from(
      document.querySelectorAll<HTMLButtonElement>('[data-lightbox]')
    );
    let activeIndex = 0;

    function showImage(index: number) {
      if (!lbImage || !lbCaption || triggers.length === 0) return;
      activeIndex = (index + triggers.length) % triggers.length;
      const trigger = triggers[activeIndex];
      lbImage.src = trigger.dataset.full || '';
      lbImage.alt = trigger.dataset.alt || '';
      lbCaption.textContent = `Photo ${activeIndex + 1} of ${triggers.length}`;
    }

    function openLightbox(index: number) {
      if (!lightbox) return;
      showImage(index);
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      if (!lightbox) return;
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = '';
    }

    triggers.forEach((trigger, i) => {
      trigger.addEventListener('click', () => openLightbox(i));
    });

    document.getElementById('lb-close')?.addEventListener('click', closeLightbox);
    document
      .getElementById('lb-prev')
      ?.addEventListener('click', () => showImage(activeIndex - 1));
    document
      .getElementById('lb-next')
      ?.addEventListener('click', () => showImage(activeIndex + 1));

    lightbox?.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    document.addEventListener('keydown', (e) => {
      if (!lightbox || lightbox.classList.contains('hidden')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') showImage(activeIndex - 1);
      if (e.key === 'ArrowRight') showImage(activeIndex + 1);
    });
  </script>
</BaseLayout>
