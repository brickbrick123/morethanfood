---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, social } from '../data/site';

const channels = [
  {
    label: 'Email us',
    value: site.email,
    href: `mailto:${site.email}`,
    note: 'The fastest way to reach the team directly.',
  },
  {
    label: 'Instagram',
    value: '@morethanfood.nonprofit',
    href: social.instagram,
    note: 'Follow along for service events and updates.',
  },
  {
    label: 'LinkedIn',
    value: 'More Than Food, NPO',
    href: social.linkedin,
    note: 'Connect with us for partnerships and outreach.',
  },
];
---

<BaseLayout
  title="Contact Us"
  description="Get in touch with More Than Food — whether you want to volunteer, partner, or simply learn more about our mission."
>
  <!-- ================= HEADER ================= -->
  <section class="bg-forest pb-16 pt-20 sm:pb-20 sm:pt-28">
    <div class="container-content">
      <span class="eyebrow-light">
        <span class="h-px w-7 bg-current opacity-50"></span>
        Contact Us
      </span>
      <h1
        class="mt-6 max-w-3xl text-balance font-display text-[2.5rem] font-900 leading-[1.05] tracking-tight text-cream sm:text-6xl"
      >
        Let's start a conversation.
      </h1>
      <p class="mt-5 max-w-xl text-pretty text-lg leading-relaxed text-cream/75">
        Want to volunteer, partner with us, or bring More Than Food to your
        community? We would love to hear from you.
      </p>
    </div>
  </section>

  <!-- ================= CONTACT BODY ================= -->
  <section class="bg-cream py-16 sm:py-24">
    <div class="container-content">
      <div class="grid gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:gap-16">
        <!-- Channels -->
        <div class="reveal">
          <h2 class="font-display text-2xl font-700 text-forest">
            Reach us directly
          </h2>
          <p class="mt-3 text-pretty leading-relaxed text-ink/70">
            Prefer to reach out yourself? Here is where to find us.
          </p>
          <ul class="mt-8 space-y-4">
            {
              channels.map((channel) => (
                <li>
                  <a
                    href={channel.href}
                    target={channel.href.startsWith('http') ? '_blank' : undefined}
                    rel={
                      channel.href.startsWith('http')
                        ? 'noopener noreferrer'
                        : undefined
                    }
                    class="block rounded-3xl border border-forest/10 bg-paper p-6 transition-all duration-200 hover:-translate-y-0.5 hover:border-forest/25 hover:shadow-card"
                  >
                    <span class="text-xs font-semibold uppercase tracking-[0.16em] text-ember-600">
                      {channel.label}
                    </span>
                    <span class="mt-1.5 block break-words font-display text-lg font-600 text-forest">
                      {channel.value}
                    </span>
                    <span class="mt-1 block text-sm text-ink/60">
                      {channel.note}
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Form -->
        <div class="reveal" style="transition-delay: 100ms;">
          <div class="rounded-4xl border border-forest/10 bg-paper p-7 shadow-card sm:p-10">
            <h2 class="font-display text-2xl font-700 text-forest">
              Send us a message
            </h2>
            <p class="mt-2 text-sm text-ink/60">
              Fill out the form below and we will get back to you as soon as we
              can.
            </p>

            <form id="contact-form" class="mt-7 grid gap-5" novalidate>
              <input type="hidden" name="form_type" value="Contact" />
              <!-- Honeypot: hidden from users, catches bots -->
              <div class="hidden" aria-hidden="true">
                <label
                  >Leave this field empty
                  <input type="text" name="company" tabindex="-1" autocomplete="off" />
                </label>
              </div>

              <div class="grid gap-5 sm:grid-cols-2">
                <div>
                  <label class="field-label" for="name">Name</label>
                  <input
                    class="field-input"
                    id="name"
                    name="name"
                    type="text"
                    autocomplete="name"
                    required
                  />
                </div>
                <div>
                  <label class="field-label" for="email">Email</label>
                  <input
                    class="field-input"
                    id="email"
                    name="email"
                    type="email"
                    autocomplete="email"
                    required
                  />
                </div>
              </div>

              <div class="grid gap-5 sm:grid-cols-2">
                <div>
                  <label class="field-label" for="phone">Phone</label>
                  <input
                    class="field-input"
                    id="phone"
                    name="phone"
                    type="tel"
                    autocomplete="tel"
                  />
                </div>
                <div>
                  <label class="field-label" for="address">Address</label>
                  <input
                    class="field-input"
                    id="address"
                    name="address"
                    type="text"
                    autocomplete="street-address"
                  />
                </div>
              </div>

              <div>
                <label class="field-label" for="subject">Subject</label>
                <input
                  class="field-input"
                  id="subject"
                  name="subject"
                  type="text"
                  required
                />
              </div>

              <div>
                <label class="field-label" for="message">Message</label>
                <textarea
                  class="field-input min-h-[140px] resize-y"
                  id="message"
                  name="message"
                  rows="5"
                  required></textarea>
              </div>

              <button type="submit" class="btn-primary mt-1 w-full sm:w-auto">
                <span data-submit-label>Submit</span>
              </button>

              <p
                id="form-status"
                class="hidden rounded-xl px-4 py-3 text-sm font-medium"
                role="status"
                aria-live="polite"
              >
              </p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const status = document.getElementById('form-status');
    const submitBtn = form?.querySelector(
      'button[type="submit"]'
    ) as HTMLButtonElement | null;
    const submitLabel = form?.querySelector('[data-submit-label]');

    function setStatus(message: string, ok: boolean) {
      if (!status) return;
      status.textContent = message;
      status.classList.remove('hidden');
      status.classList.toggle('bg-forest/10', ok);
      status.classList.toggle('text-forest', ok);
      status.classList.toggle('bg-ember/15', !ok);
      status.classList.toggle('text-ember-700', !ok);
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      if (submitBtn) submitBtn.disabled = true;
      if (submitLabel) submitLabel.textContent = 'Sending…';

      try {
        const data = Object.fromEntries(new FormData(form).entries());
        const res = await fetch('/api/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          form.reset();
          setStatus(
            'Thank you for reaching out. We will be in touch soon.',
            true
          );
        } else {
          const body = await res.json().catch(() => ({}));
          setStatus(
            body.error ||
              'Something went wrong. Please email us directly at wearemorethanfood@gmail.com.',
            false
          );
        }
      } catch {
        setStatus(
          'Could not send your message. Please email us directly at wearemorethanfood@gmail.com.',
          false
        );
      } finally {
        if (submitBtn) submitBtn.disabled = false;
        if (submitLabel) submitLabel.textContent = 'Submit';
      }
    });
  </script>
</BaseLayout>
