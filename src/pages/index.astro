---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { site } from '../data/site';

import heroImg from '../assets/images/home-team.jpeg';
import eventImg from '../assets/images/home-event.jpg';
import aboutImg from '../assets/images/about.jpg';

// Gallery for the "in action" preview
const galleryModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/gallery/*.jpg',
  { eager: true }
);
const gallery = Object.entries(galleryModules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, mod]) => mod.default);
const preview = [
  gallery[0],
  gallery[4],
  gallery[8],
  gallery[13],
  gallery[18],
  gallery[20],
].filter(Boolean);

const stats = [
  { value: 'Thousands', label: 'Individuals served every year' },
  { value: 'Spring 2023', label: 'Serving communities since' },
  { value: 'Nationwide', label: 'Reaching shelters across the country' },
];
---

<BaseLayout
  title={undefined}
  description="More Than Food is a nonprofit bringing two communities together through shared meals — serving homeless shelters and creating experiences that connect students, athletes, and families."
>
  <!-- ================= HERO ================= -->
  <section class="relative isolate overflow-hidden bg-forest">
    <div class="absolute inset-0 -z-10">
      <Image
        src={heroImg}
        alt="More Than Food volunteers gathered together at a community service event"
        widths={[768, 1280, 1920, 2400]}
        sizes="100vw"
        class="h-full w-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
      />
      <div
        class="absolute inset-0"
        style="background: linear-gradient(110deg, rgba(8,36,23,0.94) 0%, rgba(8,36,23,0.80) 42%, rgba(14,55,34,0.55) 72%, rgba(14,55,34,0.30) 100%);"
      >
      </div>
    </div>

    <div class="container-content flex min-h-[640px] flex-col justify-center py-24 lg:min-h-[760px] lg:py-32">
      <div class="max-w-2xl">
        <span class="eyebrow-light animate-fade-up">
          <span class="h-px w-7 bg-current opacity-50"></span>
          Nonprofit &middot; Established {site.founded}
        </span>
        <h1
          class="mt-6 text-balance font-display text-[2.7rem] font-900 leading-[1.04] tracking-tight text-cream animate-fade-up sm:text-6xl lg:text-[4.4rem]"
          style="animation-delay: 80ms;"
        >
          More than a meal. A reason to come together.
        </h1>
        <p
          class="mt-6 max-w-xl text-pretty text-lg leading-relaxed text-cream/80 animate-fade-up sm:text-xl"
          style="animation-delay: 160ms;"
        >
          More Than Food brings two communities together over a shared table —
          serving homeless shelters while creating an experience that connects
          students, athletes, families, and neighbors.
        </p>
        <div
          class="mt-9 flex flex-wrap gap-3 animate-fade-up"
          style="animation-delay: 240ms;"
        >
          <a href="/donate" class="btn-primary">Donate Here</a>
          <a href="/service-in-action" class="btn-ghost-light">See us in action</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= IMPACT STATS ================= -->
  <section class="bg-forest-800">
    <div class="container-content grid gap-px overflow-hidden sm:grid-cols-3">
      {
        stats.map((stat) => (
          <div class="reveal bg-forest-800 px-6 py-10 text-center sm:py-12">
            <p class="font-display text-3xl font-700 text-ember-300 sm:text-4xl">
              {stat.value}
            </p>
            <p class="mx-auto mt-2 max-w-[15rem] text-sm leading-relaxed text-cream/65">
              {stat.label}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ================= THE MTF WAY ================= -->
  <section class="bg-cream py-20 sm:py-28">
    <div class="container-content">
      <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:gap-16">
        <div class="reveal">
          <SectionHeading
            eyebrow="The More Than Food Way"
            title="Food is the sincerest catalyst to communion."
            intro="Since Spring 2023, More Than Food has had the pleasure of serving thousands of individuals across the country every year. But a meal is only where it begins."
          />
          <p class="mt-6 max-w-xl text-pretty leading-relaxed text-ink/70">
            One thing we do is provide meals to homeless shelters. Our purpose is
            to do much more — just as the name suggests, we are determined to
            bring together two disparate communities through food.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/about" class="btn-forest">Our story</a>
            <a href="/service-in-action" class="btn-outline">Photo gallery</a>
          </div>
        </div>

        <div class="reveal" style="transition-delay: 120ms;">
          <div class="photo-frame aspect-[4/5] shadow-card">
            <Image
              src={eventImg}
              alt="A More Than Food breakfast service event in progress"
              widths={[480, 760, 1080]}
              sizes="(min-width: 1024px) 44vw, 90vw"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= MISSION & VISION ================= -->
  <section class="bg-paper py-20 sm:py-28">
    <div class="container-content">
      <SectionHeading
        eyebrow="What drives us"
        title="Our mission and our vision"
        align="center"
        class="mb-14"
      />
      <div class="grid gap-6 lg:grid-cols-2 lg:gap-8">
        <article
          class="reveal flex flex-col rounded-4xl border border-forest/10 bg-cream p-8 sm:p-10"
        >
          <span
            class="flex h-12 w-12 items-center justify-center rounded-2xl bg-forest text-cream"
            aria-hidden="true"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 21s-7-4.35-9.5-9A5.5 5.5 0 0 1 12 6a5.5 5.5 0 0 1 9.5 6c-2.5 4.65-9.5 9-9.5 9z"></path>
            </svg>
          </span>
          <h3 class="mt-6 font-display text-2xl font-700 text-forest">Our Mission</h3>
          <p class="mt-3 text-pretty leading-relaxed text-ink/70">
            One thing we do is provide meals to homeless shelters, but our
            purpose is to do much more. Just as the name suggests, we are
            determined to bring together two disparate communities through food —
            the sincerest catalyst to communion.
          </p>
        </article>

        <article
          class="reveal flex flex-col rounded-4xl border border-forest/10 bg-cream p-8 sm:p-10"
          style="transition-delay: 120ms;"
        >
          <span
            class="flex h-12 w-12 items-center justify-center rounded-2xl bg-ember text-ink"
            aria-hidden="true"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="3"></circle>
              <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"></path>
            </svg>
          </span>
          <h3 class="mt-6 font-display text-2xl font-700 text-forest">Our Vision</h3>
          <p class="mt-3 text-pretty leading-relaxed text-ink/70">
            For More Than Food to be a nationally recognized organization that
            provides a unique experience to all communities. We welcome everyone
            to our events — students, sports teams, employers, families, and
            many others.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- ================= IN ACTION PREVIEW ================= -->
  <section class="bg-cream py-20 sm:py-28">
    <div class="container-content">
      <div
        class="mb-12 flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between"
      >
        <SectionHeading
          eyebrow="Service in action"
          title="The people who make a difference"
        />
        <a
          href="/service-in-action"
          class="btn-outline shrink-0 self-start sm:self-auto"
        >
          View full gallery
        </a>
      </div>

      <div class="grid grid-cols-2 gap-3 sm:gap-4 lg:grid-cols-3">
        {
          preview.map((img, i) => (
            <div
              class:list={[
                'photo-frame reveal',
                i === 0 ? 'col-span-2 aspect-[16/10] lg:col-span-1 lg:aspect-square' : 'aspect-square',
              ]}
              style={`transition-delay: ${i * 70}ms;`}
            >
              <Image
                src={img}
                alt="More Than Food volunteers and community members at a service event"
                widths={[360, 560, 800]}
                sizes="(min-width: 1024px) 30vw, 45vw"
              />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ================= CLOSING CTA ================= -->
  <section class="relative isolate overflow-hidden bg-forest py-20 sm:py-28">
    <div class="absolute inset-0 -z-10 opacity-25">
      <Image
        src={aboutImg}
        alt=""
        widths={[768, 1280, 1920]}
        sizes="100vw"
        class="h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-forest/75"></div>
    </div>
    <div class="container-content text-center">
      <div class="reveal mx-auto max-w-2xl">
        <h2
          class="text-balance font-display text-[2.1rem] font-800 leading-tight text-cream sm:text-5xl"
        >
          Every dollar becomes a meal, and every meal becomes a connection.
        </h2>
        <p class="mx-auto mt-5 max-w-xl text-pretty text-lg text-cream/75">
          More Than Food would not exist without the selfless individual behind
          each contribution. Join the movement today.
        </p>
        <div class="mt-9 flex flex-wrap justify-center gap-3">
          <a href="/donate" class="btn-primary">Donate Here</a>
          <a href="/contact" class="btn-ghost-light">Get in touch</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
